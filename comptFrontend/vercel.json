{
  "rewrites": [
    { "source": "/auth/:path*",        "destination": "https://compt-bmhy.vercel.app/auth/:path*" },
    { "source": "/companies/:path*",   "destination": "https://compt-bmhy.vercel.app/companies/:path*" },
    { "source": "/accounting/:path*",  "destination": "https://compt-bmhy.vercel.app/accounting/:path*" },
    { "source": "/super-admin/:path*", "destination": "https://compt-bmhy.vercel.app/super-admin/:path*" },
    { "source": "/profile/:path*",     "destination": "https://compt-bmhy.vercel.app/profile/:path*" },
    { "source": "/(.*)",               "destination": "/index.html" }
  ]
}
